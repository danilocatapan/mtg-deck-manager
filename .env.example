POSTGRES_DB=mtg_deck_manager
POSTGRES_USER=mtg
POSTGRES_PASSWORD=mtg_dev_password
POSTGRES_PORT=5432

QUARKUS_DATASOURCE_DB_KIND=postgresql
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://localhost:5432/mtg_deck_manager
QUARKUS_DATASOURCE_USERNAME=mtg
QUARKUS_DATASOURCE_PASSWORD=mtg_dev_password
QUARKUS_FLYWAY_MIGRATE_AT_START=true
QUARKUS_HIBERNATE_ORM_SCHEMA_MANAGEMENT_STRATEGY=validate

# Set this only when testing Google/OIDC locally.
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
CORS_ORIGINS=http://localhost:5173,https://danilocatapan.github.io
SWAGGER_UI_ENABLED=true
APP_LOG_LEVEL=INFO
VITE_API_URL=http://localhost:8080

# GitHub Actions / staging smoke tests.
# BACKEND_DEPLOY_HOOK_URL is a GitHub Actions secret, not a local env requirement.
# STAGING_API_URL=https://your-staging-api.example.com
# STAGING_BEARER_TOKEN=google-id-token-for-smoke-tests
