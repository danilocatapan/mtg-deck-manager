POSTGRES_DB=mtg_deck_manager
POSTGRES_USER=mtg
POSTGRES_PASSWORD=mtg_dev_password
POSTGRES_PORT=5432

QUARKUS_DATASOURCE_DB_KIND=postgresql
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://localhost:5432/mtg_deck_manager
QUARKUS_DATASOURCE_USERNAME=mtg
QUARKUS_DATASOURCE_PASSWORD=mtg_dev_password
QUARKUS_FLYWAY_MIGRATE_AT_START=true
QUARKUS_HIBERNATE_ORM_SCHEMA_MANAGEMENT_STRATEGY=validate

# Set this only when testing Google/OIDC locally.
# Configure the Google OAuth consent/client with only: openid, email, profile.
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Comma-separated Google subject IDs allowed to call POST /security/status/check.
# Keep real values in deployment secrets only; do not commit personal/admin identifiers.
# SECURITY_ADMIN_SUBJECTS=google-subject-id-1,google-subject-id-2
CORS_ORIGINS=http://localhost:5173,https://danilocatapan.github.io
SWAGGER_UI_ENABLED=true
APP_LOG_LEVEL=WARN
SECURITY_STATUS_LOG_LEVEL=INFO
FRONTEND_URL=https://danilocatapan.github.io/mtg-deck-manager/
VITE_API_URL=http://localhost:8080
# Optional contact form endpoint for the public Contact page.
# VITE_CONTACT_FORM_ENDPOINT=https://formspree.io/f/your-form-id

# GitHub Actions / staging smoke tests.
# BACKEND_DEPLOY_HOOK_URL is a GitHub Actions secret, not a local env requirement.
# STAGING_API_URL=https://your-staging-api.example.com
# STAGING_BEARER_TOKEN=google-id-token-for-smoke-tests
